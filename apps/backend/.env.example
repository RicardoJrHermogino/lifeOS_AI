# ==========================================================
# BACKEND API ENVIRONMENT VARIABLES
# ==========================================================

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3001,http://localhost:3000,http://192.168.x.x:3000

# Database
DATABASE_URL="postgres://postgres:password@localhost:5432/lifeosai"

# Authentication (Better Auth)
BETTER_AUTH_SECRET=default-secret-for-testing-change-in-production
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001,http://localhost:3000,http://192.168.x.x:3000
BETTER_AUTH_COOKIE_DOMAIN=

# OAuth Providers (Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================================
# LIFEOS — AI / JOBS / STORAGE
# ==========================================================

# AI Provider (OpenAI or compatible)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Job Queue (BullMQ via Redis)
REDIS_URL=redis://localhost:6379

# Object Storage (S3-compatible) — audio uploads + data exports
STORAGE_BUCKET=lifeosai-uploads
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_REGION=auto
