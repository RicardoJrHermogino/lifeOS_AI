{
	"name": "turbo-template",
	"private": true,
	"engines": {
		"node": ">=22.20.0",
		"pnpm": ">=10.15.1"
	},
	"packageManager": "pnpm@10.27.0",
	"scripts": {
		"build": "turbo run build",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo run clean",
		"auth:generate": "pnpm -F @repo/auth generate",
		"db:push": "pnpm -F @repo/db push",
		"db:studio": "turbo -F @repo/db studio",
		"db:generate": "turbo -F @repo/db generate",
		"db:migrate": "turbo -F @repo/db migrate",
		"db:seed": "pnpm -F @repo/db seed",
		"dev": "turbo watch dev --continue",
		"dev:web": "turbo watch dev -F @repo/web...",
		"dev:mobile": "turbo watch dev -F @repo/mobile...",
		"dev:mobile-run": "pnpm -F @repo/mobile run dev:mobile",
		"dev:backend": "turbo watch dev -F @repo/backend...",
		"start": "turbo run start",
		"test": "turbo run test",
		"test:cov": "turbo run test:cov",
		"format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
		"format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
		"lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
		"lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
		"lint:ws": "pnpm dlx sherif@latest",
		"postinstall": "node -e \"try { require('node:child_process').execSync('pnpm lint:ws', { stdio: 'inherit' }) } catch { console.warn('Skipping workspace dependency check during postinstall') }\"",
		"test:e2e:web": "turbo run test:e2e --filter=@repo/e2e-web",
		"show-report:e2e:web": "pnpm --filter @repo/e2e-web run show-report",
		"typecheck": "turbo run typecheck",
		"prepare": "husky"
	},
	"devDependencies": {
		"@repo/prettier-config": "workspace:*",
		"@turbo/gen": "catalog:",
		"husky": "^9.1.7",
		"prettier": "catalog:",
		"turbo": "catalog:",
		"typescript": "catalog:"
	},
	"prettier": "@repo/prettier-config"
}
